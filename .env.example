# URL do projeto Supabase — não é secreta, é só o endereço da API.
NEXT_PUBLIC_SUPABASE_URL=https://metzhlilouokuvkilgrw.supabase.co

# Chave "publishable" (antigo "anon key") do Supabase — projetada pra ser
# exposta no bundle do navegador; o que protege os dados é a Row Level
# Security de cada tabela, não o sigilo desta chave. Por isso o prefixo
# NEXT_PUBLIC_ aqui é correto, não um erro de configuração.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Este projeto não usa (e não deve usar) a service_role key do Supabase em
# nenhum dos dois apps — todas as operações do servidor (rotas de API,
# Server Components) autenticam com a sessão do usuário via cookies, nunca
# com uma chave de administrador do banco. Se isso mudar no futuro, essa
# chave NUNCA pode levar o prefixo NEXT_PUBLIC_ (viraria pública no bundle).
